{
     "info": {
          "name": "Leonardo Backend - Basic API Tests",
          "_postman_id": "leonardo-basic-collection",
          "description": "Basic Postman collection for testing Leonardo backend APIs.",
          "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
     },
     "variable": [
          {
               "key": "base_api",
               "value": "http://10.10.7.103:7002",
               "type": "string"
          },
          {
               "key": "auth_token",
               "value": "",
               "type": "string"
          }
     ],
     "item": [
          {
               "name": "Auth - Login",
               "request": {
                    "method": "POST",
                    "header": [{ "key": "Content-Type", "value": "application/json" }],
                    "body": {
                         "mode": "raw",
                         "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
                    },
                    "url": { "raw": "{{base_api}}/auth/login", "host": ["{{base_api}}"], "path": ["auth", "login"] }
               }
          },
          {
               "name": "Auth - Refresh Token",
               "request": {
                    "method": "POST",
                    "header": [
                         { "key": "Content-Type", "value": "application/json" },
                         { "key": "Authorization", "value": "Bearer {{auth_token}}" }
                    ],
                    "url": { "raw": "{{base_api}}/auth/refresh-token", "host": ["{{base_api}}"], "path": ["auth", "refresh-token"] }
               }
          },
          {
               "name": "Auth - Forget Password",
               "request": {
                    "method": "POST",
                    "header": [{ "key": "Content-Type", "value": "application/json" }],
                    "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@example.com\"\n}" },
                    "url": { "raw": "{{base_api}}/auth/forget-password", "host": ["{{base_api}}"], "path": ["auth", "forget-password"] }
               }
          },
          {
