                    "method": "POST",
                    "header": [{ "key": "Content-Type", "value": "application/json" }],
                    "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@example.com\",\n  \"otp\": \"123456\"\n}" },
                    "url": { "raw": "{{base_api}}/auth/verify-email", "host": ["{{base_api}}"], "path": ["auth", "verify-email"] }
               }
          },
          {
               "name": "Auth - Reset Password",
               "request": {
                    "method": "POST",
                    "header": [{ "key": "Content-Type", "value": "application/json" }],
                    "body": { "mode": "raw", "raw": "{\n  \"token\": \"<resetToken>\",\n  \"password\": \"newPassword123\"\n}" },
                    "url": { "raw": "{{base_api}}/auth/reset-password", "host": ["{{base_api}}"], "path": ["auth", "reset-password"] }
               }
          },
          {
               "name": "Auth - Dashboard Forget Password",
               "request": {
                    "method": "POST",
                    "header": [{ "key": "Content-Type", "value": "application/json" }],
                    "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@example.com\"\n}" },
